# Frontend Production Environment Template
# Copy this to .env.production in the frontend directory

# ==================== API ENDPOINTS ====================
# Replace with your Render backend URL
VITE_API_URL=https://mediconnect-backend.onrender.com

# ==================== SOCKET.IO ====================
# Same as backend URL (socket.io runs on same server)
VITE_SOCKET_URL=https://mediconnect-backend.onrender.com

# ==================== ANALYTICS (Optional) ====================
# Vercel Analytics is automatically enabled
# Add your custom analytics tracking IDs here if needed

# ==================== FEATURE FLAGS ====================
VITE_ENABLE_CHAT=true
VITE_ENABLE_VIDEO_CALLS=true
VITE_ENABLE_MEDICINE_SEARCH=true
VITE_ENABLE_APPOINTMENTS=true

# ==================== DEBUG ====================
# Set to false in production to disable console logs
VITE_DEBUG=false
