# Backend Production Environment Template
# Copy this to .env in the backend directory and fill in your values

# ==================== SERVER ====================
NODE_ENV=production
PORT=5000

# ==================== DATABASE ====================
MONGODB_URI=mongodb+srv://shreeya:shreeya@cluster0.wplasb9.mongodb.net/?appName=Cluster0
DB_NAME=MediConnect

# ==================== JWT SECRETS ====================
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACCESS_TOKEN_SECRET=your_32_character_access_token_secret_generated_via_crypto
REFRESH_TOKEN_SECRET=your_32_character_refresh_token_secret_generated_via_crypto

# ==================== TWILIO (SMS OTP) ====================
# Get from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_xxx
TWILIO_PHONE_NUMBER=+1234567890

# ==================== EMAIL (NODEMAILER) ====================
# Gmail: Use App Password (NOT regular password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_USER=mediconnect12@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_16_chars

# ==================== CLOUDINARY (FILE UPLOADS) ====================
# Get from: https://cloudinary.com/console
CLOUDINARY_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ==================== CORS & FRONTEND ====================
FRONTEND_URL=https://your-frontend-vercel-url.vercel.app
ALLOWED_ORIGINS=https://your-frontend-vercel-url.vercel.app

# ==================== COOKIES ====================
COOKIE_SECURE=true
COOKIE_SAMESITE=Lax
COOKIE_DOMAIN=your-render-backend-url.onrender.com

# ==================== RATE LIMITING ====================
RATE_LIMIT_WINDOW_MS=15000
RATE_LIMIT_MAX_REQUESTS=100

# ==================== LOGGING ====================
LOG_LEVEL=info
